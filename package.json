{
  "name": "quick-translator",
  "displayName": "Quick Translator",
  "description": "A fast VS Code extension to instantly translate selected English code/docs into Hebrew via keyboard shortcut.",
  "version": "0.0.1",
  "publisher": "tzisman",
  "repository": {
    "type": "git",
    "url": "https://github.com/tzisman/quick-translator.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "quicktranslator.translateText",
        "title": "תרגם לעברית"
      }
    ],
    "keybindings": [
      {
        "command": "quicktranslator.translateText",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/node-fetch": "^2.6.13",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1"
  },
  "license": "MIT"
}